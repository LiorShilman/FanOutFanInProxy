<Application x:Class="TcpProxy.Dashboard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <!-- Dark theme base colors -->
    <Color x:Key="BgDark">#FF1E1E2E</Color>
    <Color x:Key="BgCard">#FF2A2A3E</Color>
    <Color x:Key="BgCardBorder">#FF3A3A5E</Color>
    <Color x:Key="AccentBlue">#FF4FC3F7</Color>
    <Color x:Key="GreenOk">#FF4CAF50</Color>
    <Color x:Key="RedErr">#FFF44336</Color>
    <Color x:Key="TextPrimary">#FFEAEAEA</Color>
    <Color x:Key="TextMuted">#FF9E9E9E</Color>

    <SolidColorBrush x:Key="BrBgDark"      Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BrBgCard"      Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BrCardBorder"  Color="{StaticResource BgCardBorder}"/>
    <SolidColorBrush x:Key="BrAccent"      Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="BrGreen"       Color="{StaticResource GreenOk}"/>
    <SolidColorBrush x:Key="BrRed"         Color="{StaticResource RedErr}"/>
    <SolidColorBrush x:Key="BrTextPrimary" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrTextMuted"   Color="{StaticResource TextMuted}"/>
  </Application.Resources>
</Application>
