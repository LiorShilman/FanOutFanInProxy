<Window x:Class="TcpProxy.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TcpProxy.Dashboard.Views"
        Title="TCP Fan-Out / Fan-In Proxy — Dashboard"
        Width="980" Height="720"
        MinWidth="760" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrBgDark}">

  <Window.Resources>

    <!-- Tab style -->
    <Style x:Key="DarkTab" TargetType="TabItem">
      <Setter Property="Foreground"        Value="{StaticResource BrTextMuted}"/>
      <Setter Property="Background"        Value="Transparent"/>
      <Setter Property="BorderThickness"   Value="0"/>
      <Setter Property="Padding"           Value="18,8"/>
      <Setter Property="FontSize"          Value="12"/>
      <Setter Property="FontWeight"        Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                    Background="Transparent" BorderThickness="0,0,0,2"
                    BorderBrush="Transparent">
              <ContentPresenter ContentSource="Header"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                <Setter Property="Foreground"                   Value="{StaticResource BrAccent}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Downstream row template -->
    <DataTemplate x:Key="DownstreamTemplate">
      <Grid Margin="0,4,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="14"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="46"/>
        </Grid.ColumnDefinitions>
        <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center">
          <Ellipse.Style>
            <Style TargetType="Ellipse">
              <Setter Property="Fill" Value="{StaticResource BrRed}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Connected}" Value="True">
                  <Setter Property="Fill" Value="{StaticResource BrGreen}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Ellipse.Style>
        </Ellipse>
        <TextBlock Grid.Column="1" Text="{Binding Name}"
                   Foreground="{StaticResource BrTextPrimary}" FontSize="12"
                   VerticalAlignment="Center" Margin="6,0,4,0"
                   TextTrimming="CharacterEllipsis"/>
        <Border Grid.Column="2" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="#33F44336"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Connected}" Value="True">
                  <Setter Property="Background" Value="#334CAF50"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrRed}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Connected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrGreen}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Border>
      </Grid>
    </DataTemplate>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>   <!-- Header -->
      <RowDefinition Height="*"/>    <!-- Main content (tabs) -->
      <RowDefinition Height="180"/>  <!-- Log panel (always visible) -->
    </Grid.RowDefinitions>

    <!-- ════════════════════════ Header ══════════════════════════════════════ -->
    <Border Grid.Row="0" Background="#FF13131F" Padding="18,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="TCP Proxy" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource BrAccent}" Margin="0,0,10,0"/>
          <TextBlock Text="FAN-OUT / FAN-IN DASHBOARD" FontSize="12"
                     Foreground="{StaticResource BrTextMuted}" VerticalAlignment="Center"
                     FontWeight="SemiBold"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="{StaticResource BrRed}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource BrGreen}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <TextBlock Text="{Binding ConnectionStatus}"
                     Foreground="{StaticResource BrTextMuted}" FontSize="12"
                     VerticalAlignment="Center" Margin="0,0,18,0"/>
          <TextBlock Text="{Binding LastUpdate, StringFormat='Updated: {0}'}"
                     Foreground="{StaticResource BrTextMuted}" FontSize="11"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ════════════════════════ Tab Control ══════════════════════════════════ -->
    <TabControl Grid.Row="1"
                Background="{StaticResource BrBgDark}"
                BorderThickness="0"
                Padding="0">
      <TabControl.Resources>
        <Style TargetType="TabPanel">
          <Setter Property="Background" Value="#FF13131F"/>
        </Style>
      </TabControl.Resources>

      <!-- ── Tab 1: Flow Visualization ──────────────────────────────────── -->
      <TabItem Header="  FLOW  " Style="{StaticResource DarkTab}">
        <Grid Background="{StaticResource BrBgDark}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
          </Grid.ColumnDefinitions>
          <views:FlowCanvasControl x:Name="FlowCanvas" Grid.Column="0" Margin="10"/>
          <views:PathSwitchControl x:Name="PathSwitch" Grid.Column="1"/>
        </Grid>
      </TabItem>

      <!-- ── Tab 2: Config Builder ─────────────────────────────────────────── -->
      <TabItem Header="  CONFIG  " Style="{StaticResource DarkTab}">
        <views:ConfigCanvasControl x:Name="ConfigCanvas"/>
      </TabItem>

      <!-- ── Tab 3: Channel Details ──────────────────────────────────────── -->
      <TabItem Header="  DETAILS  " Style="{StaticResource DarkTab}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8,8,0"
                      Background="{StaticResource BrBgDark}">
          <ItemsControl ItemsSource="{Binding Channels}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="6" Padding="18,14"
                        Background="{StaticResource BrBgCard}"
                        BorderBrush="{StaticResource BrCardBorder}"
                        BorderThickness="1" CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource BrAccent}" Margin="0,0,0,12"/>

                    <TextBlock Text="UPSTREAM" Foreground="{StaticResource BrTextMuted}"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                      <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                          <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource BrRed}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding UpstreamConnected}" Value="True">
                                <Setter Property="Fill" Value="{StaticResource BrGreen}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Ellipse.Style>
                      </Ellipse>
                      <TextBlock Text="{Binding UpstreamLabel}" FontSize="13" FontWeight="Bold">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource BrRed}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding UpstreamConnected}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BrGreen}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>

                    <TextBlock Text="DOWNSTREAMS" Foreground="{StaticResource BrTextMuted}"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding Downstreams}"
                                  ItemTemplate="{StaticResource DownstreamTemplate}"
                                  Margin="0,0,0,14"/>

                    <Separator Background="{StaticResource BrCardBorder}" Margin="0,0,0,12"/>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="RX TOTAL" Foreground="{StaticResource BrTextMuted}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding RxDisplay}"
                                   Foreground="{StaticResource BrTextPrimary}"
                                   FontSize="15" FontWeight="SemiBold"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="TX TOTAL" Foreground="{StaticResource BrTextMuted}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding TxDisplay}"
                                   Foreground="{StaticResource BrTextPrimary}"
                                   FontSize="15" FontWeight="SemiBold"/>
                      </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="RECONNECTS" Foreground="{StaticResource BrTextMuted}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ReconnectCount}"
                                   Foreground="#FFFFB74D" FontSize="15" FontWeight="SemiBold"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="DROPPED" Foreground="{StaticResource BrTextMuted}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding DroppedPackets}"
                                   Foreground="{StaticResource BrRed}"
                                   FontSize="15" FontWeight="SemiBold"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <!-- ════════════════════════ Log Panel ════════════════════════════════════ -->
    <Border Grid.Row="2" Background="#FF13131F"
            BorderBrush="{StaticResource BrCardBorder}" BorderThickness="0,1,0,0">
      <Grid Margin="14,8,14,8">
        <Grid.RowDefinitions>
          <RowDefinition Height="22"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="RECENT EVENTS"
                   Foreground="{StaticResource BrTextMuted}"
                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
        <ListBox Grid.Row="1" x:Name="LogListBox"
                 ItemsSource="{Binding RecentLogs}"
                 Background="Transparent" BorderThickness="0"
                 Foreground="{StaticResource BrTextMuted}"
                 FontSize="12" FontFamily="Consolas"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.ScrollUnit="Pixel">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding"    Value="0,1"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter Margin="{TemplateBinding Padding}"/>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</Window>
