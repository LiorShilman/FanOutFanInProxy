<UserControl x:Class="TcpProxy.Dashboard.Views.PathSwitchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Background="#FF0C0C1A"
          BorderBrush="{StaticResource BrCardBorder}"
          BorderThickness="1,0,0,0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- ══ Header ═══════════════════════════════════════════════════════════ -->
      <Border Grid.Row="0" Background="#FF111120"
              BorderBrush="{StaticResource BrCardBorder}" BorderThickness="0,0,0,1">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Rectangle Grid.Column="0" Fill="{StaticResource BrAccent}"/>
          <StackPanel Grid.Column="1" Margin="14,11,14,11">
            <TextBlock Text="PATH" FontSize="13" FontWeight="Bold"
                       Foreground="{StaticResource BrTextPrimary}"/>
            <TextBlock Text="Active link selection" FontSize="10"
                       Foreground="{StaticResource BrTextMuted}" Margin="0,2,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal"
                      VerticalAlignment="Center" Margin="0,0,10,0">
            <Button x:Name="BtnBlockAll" Content="BLOCK ALL"
                    Click="BtnBlockAll_Click"
                    FontSize="9" FontWeight="Bold" Padding="7,3"
                    Foreground="#FFF44336" Background="#1AF44336"
                    BorderBrush="#55F44336" BorderThickness="1"
                    Cursor="Hand" VerticalAlignment="Center" Margin="0,0,8,0">
              <Button.Style>
                <Style TargetType="Button">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#33F44336"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </Button.Style>
            </Button>
            <Ellipse x:Name="CmdStatusDot" Width="8" Height="8"
                     Fill="#FF3A3A5E" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock x:Name="CmdStatusText" Text="–" FontSize="9"
                       Foreground="{StaticResource BrTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ══ Not applicable (topology != 2 channels) ══════════════════════════ -->
      <Border x:Name="PanelNotApplicable" Grid.Row="1"
              Visibility="Collapsed" Padding="20,40">
        <TextBlock Text="Path switch not available&#x0a;for this topology."
                   Foreground="{StaticResource BrTextMuted}"
                   FontSize="11" TextAlignment="Center"
                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
      </Border>

      <!-- ══ Two-path switch ═══════════════════════════════════════════════════ -->
      <StackPanel x:Name="PanelTwoPath" Grid.Row="1"
                  Margin="14,20,14,16" VerticalAlignment="Top">

        <!-- ── Card A ──────────────────────────────────────────────────────── -->
        <Border x:Name="CardA"
                CornerRadius="10" BorderThickness="2" Padding="16,14"
                MouseLeftButtonDown="CardA_Click"
                MouseEnter="CardA_MouseEnter" MouseLeave="CardA_MouseLeave">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name row -->
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="DotA" Grid.Column="0"
                         Text="◉" FontSize="16" VerticalAlignment="Center"
                         Margin="0,0,9,0"/>
              <TextBlock x:Name="NameA" Grid.Column="1"
                         Text="—" FontSize="24" FontWeight="Bold"
                         Foreground="{StaticResource BrTextPrimary}"
                         VerticalAlignment="Center"/>
              <Border x:Name="BadgeA" Grid.Column="2"
                      CornerRadius="4" Padding="7,3" VerticalAlignment="Center">
                <TextBlock x:Name="BadgeTextA" Text="—"
                           FontSize="9" FontWeight="Bold"/>
              </Border>
            </Grid>

            <!-- Divider -->
            <Border Grid.Row="1" Height="1" Margin="0,10"
                    Background="{StaticResource BrCardBorder}"/>

            <!-- Status row -->
            <TextBlock x:Name="StatusA" Grid.Row="2"
                       Text="○  Waiting…"
                       Foreground="{StaticResource BrTextMuted}" FontSize="11"/>
          </Grid>
        </Border>

        <!-- ── OR divider ──────────────────────────────────────────────────── -->
        <Grid Height="34">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                  Background="{StaticResource BrCardBorder}" Margin="0,0,10,0"/>
          <TextBlock Grid.Column="1" Text="OR"
                     Foreground="{StaticResource BrTextMuted}"
                     FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                  Background="{StaticResource BrCardBorder}" Margin="10,0,0,0"/>
        </Grid>

        <!-- ── Card B ──────────────────────────────────────────────────────── -->
        <Border x:Name="CardB"
                CornerRadius="10" BorderThickness="2" Padding="16,14"
                MouseLeftButtonDown="CardB_Click"
                MouseEnter="CardB_MouseEnter" MouseLeave="CardB_MouseLeave">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="DotB" Grid.Column="0"
                         Text="○" FontSize="16" VerticalAlignment="Center"
                         Margin="0,0,9,0"/>
              <TextBlock x:Name="NameB" Grid.Column="1"
                         Text="—" FontSize="24" FontWeight="Bold"
                         Foreground="{StaticResource BrTextPrimary}"
                         VerticalAlignment="Center"/>
              <Border x:Name="BadgeB" Grid.Column="2"
                      CornerRadius="4" Padding="7,3" VerticalAlignment="Center">
                <TextBlock x:Name="BadgeTextB" Text="—"
                           FontSize="9" FontWeight="Bold"/>
              </Border>
            </Grid>

            <Border Grid.Row="1" Height="1" Margin="0,10"
                    Background="{StaticResource BrCardBorder}"/>

            <TextBlock x:Name="StatusB" Grid.Row="2"
                       Text="○  Waiting…"
                       Foreground="{StaticResource BrTextMuted}" FontSize="11"/>
          </Grid>
        </Border>

      </StackPanel>

    </Grid>
  </Border>
</UserControl>
